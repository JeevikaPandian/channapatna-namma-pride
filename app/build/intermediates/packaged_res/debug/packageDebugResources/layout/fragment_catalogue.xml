<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Filter Pills -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/filter_all"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_filter_pill"
                android:paddingHorizontal="14dp"
                android:text="All Toys"
                android:textSize="11sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/filter_tops"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_filter_pill"
                android:paddingHorizontal="14dp"
                android:text="🌀 Tops"
                android:textSize="11sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/filter_horses"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_filter_pill"
                android:paddingHorizontal="14dp"
                android:text="🐴 Horses"
                android:textSize="11sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/filter_dolls"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_filter_pill"
                android:paddingHorizontal="14dp"
                android:text="🪆 Dolls"
                android:textSize="11sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/filter_animals"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_filter_pill"
                android:paddingHorizontal="14dp"
                android:text="🐘 Animals"
                android:textSize="11sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/filter_puzzles"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_filter_pill"
                android:paddingHorizontal="14dp"
                android:text="🧩 Puzzles"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Toy Grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_toys"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false" />

</LinearLayout>
