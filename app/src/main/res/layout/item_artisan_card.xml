<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="120dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="10dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tv_artisan_emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👨‍🎨"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/tv_artisan_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="Ramu Shilpi"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_artisan_specialty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center"
            android:text="Spinning Tops"
            android:textColor="@color/text_muted"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tv_artisan_rating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="⭐ 4.9"
            android:textColor="@color/forest"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
